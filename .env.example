# ============================================================
# FITSTOP – Environment Variables
# ============================================================
# Copy this file to load_env.env for local development.
# On Render (or any other host), set these as environment
# variables through the platform dashboard instead.
# NEVER commit the actual secrets file to source control.
# ============================================================

# ------------------------------------------------------------------
# Database driver
# ------------------------------------------------------------------
# Options: sqlite | mysql | pgsql
#   sqlite – file-based SQLite database (local development only)
#   mysql  – managed MySQL / MariaDB server
#   pgsql  – managed PostgreSQL server (recommended for Render)
# ------------------------------------------------------------------
DB_DRIVER = sqlite

# ------------------------------------------------------------------
# MySQL / PostgreSQL connection settings
# Leave blank when using SQLite.
# ------------------------------------------------------------------
DB_HOST =
DB_PORT =
DB_NAME =
DB_USER =
DB_PASS =

# ------------------------------------------------------------------
# AI / Groq API
# ------------------------------------------------------------------
API_BEARER_TOKEN =
API_URL = https://api.groq.com/openai/v1/chat/completions

# ------------------------------------------------------------------
# SMTP (for email verification / notifications)
# ------------------------------------------------------------------
SMTP_USERNAME =
SMTP_PASSWORD =
